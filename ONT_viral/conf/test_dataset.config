/*
 * Test profile using the bundled test_dataset (53,439 ONT reads, 169 Mb)
 * Run: nextflow run main.nf -profile docker,test_dataset --kraken2_db /path/to/db
 */
params {
    input           = "${projectDir}/test/samplesheet_test_dataset.csv"
    outdir          = 'test_results'

    // No host depletion for the test run (set to a human genome FASTA to enable)
    host_genome     = null

    // Annotation databases — set these if available
    blast_db        = null
    diamond_db      = null

    // Relaxed QC thresholds for test data
    min_length      = 200
    max_length      = 50000
    min_quality     = 7

    // Lighter resource limits for local test
    max_memory      = '16.GB'
    max_cpus        = 8
    max_time        = '4.h'

    // Coverage for top 5 pathogens
    coverage_top_n  = 5
}
