/*
 * OMOP CDM Standardization Pipeline — Nextflow configuration
 */

manifest {
    name            = 'omop-cdm-pipeline'
    author          = 'Data Engineering Team'
    description     = 'Standardize raw clinical/claims data to OMOP CDM v5.4 using DuckDB'
    version         = '1.0.0'
    nextflowVersion = '>=23.04.0'
    mainScript      = 'main.nf'
}

// ─── Default parameters ───────────────────────────────────────────────────────

params {
    // ── Required inputs ───────────────────────────────────────────────────────
    raw_data_dir         = null   // Dir with raw source CSVs/TSVs
    vocabulary_dir       = null   // Dir with OMOP vocabulary files
    source_mapping_file  = null   // JSON mapping config (source table → OMOP domain)

    // ── Optional inputs ───────────────────────────────────────────────────────
    vocabulary_update_dir = null  // Dir with updated vocabulary files for incremental update

    // ── Output ────────────────────────────────────────────────────────────────
    outdir               = 'results'

    // ── ETL behaviour ─────────────────────────────────────────────────────────
    // CDM version to target
    cdm_version          = '5.4'
    // Delimiter for raw source files (',' or '\t')
    source_delimiter     = ','
    // Minimum mapping coverage % to warn on (0-100)
    mapping_warn_threshold = 80
    // Write unmapped source codes to a separate report
    report_unmapped      = true

    // ── Profiling ─────────────────────────────────────────────────────────────
    profiling_top_n      = 20     // Top N unmapped codes to highlight
    profiling_formats    = 'html,tsv'  // Output formats: html, tsv, png

    // ── Reverse engineering ───────────────────────────────────────────────────
    // Export full audit trail as Parquet in addition to TSV
    audit_parquet        = true

    // ── Update ────────────────────────────────────────────────────────────────
    // Re-run full ETL after update (true) or only patch changed concepts (false)
    update_full_remap    = false

    // ── Resources ─────────────────────────────────────────────────────────────
    max_memory           = '32.GB'
    max_cpus             = 8
    max_time             = '24.h'

    // ── DuckDB memory cap (passed to DuckDB SET memory_limit) ─────────────────
    duckdb_memory        = '16GB'
    duckdb_threads       = 4
}

// ─── Process defaults ─────────────────────────────────────────────────────────

process {
    cpus   = { check_max(2    * task.attempt, 'cpus')   }
    memory = { check_max(8.GB * task.attempt, 'memory') }
    time   = { check_max(4.h  * task.attempt, 'time')   }

    errorStrategy = { task.exitStatus in [143,137,104,134,139] ? 'retry' : 'finish' }
    maxRetries    = 2

    withLabel: process_low {
        cpus   = { check_max(2   * task.attempt, 'cpus')   }
        memory = { check_max(4.GB * task.attempt, 'memory') }
        time   = { check_max(2.h  * task.attempt, 'time')   }
    }
    withLabel: process_medium {
        cpus   = { check_max(4   * task.attempt, 'cpus')   }
        memory = { check_max(16.GB * task.attempt, 'memory') }
        time   = { check_max(8.h   * task.attempt, 'time')   }
    }
    withLabel: process_high {
        cpus   = { check_max(8   * task.attempt, 'cpus')   }
        memory = { check_max(32.GB * task.attempt, 'memory') }
        time   = { check_max(24.h  * task.attempt, 'time')   }
    }

    // All OMOP modules use the same Python + DuckDB container
    withName: 'OMOP_.*' {
        container = 'quay.io/biocontainers/mulled-v2-omop-duckdb:latest'
    }
}

// ─── Profiles ─────────────────────────────────────────────────────────────────

profiles {
    docker {
        docker.enabled      = true
        docker.runOptions   = '-u $(id -u):$(id -g)'
        singularity.enabled = false
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
    }
    // Run without containers — requires Python + DuckDB installed locally
    local {
        process.executor    = 'local'
        docker.enabled      = false
        singularity.enabled = false
    }
    test {
        params.raw_data_dir         = "${projectDir}/test/raw_data"
        params.vocabulary_dir       = "${projectDir}/test/vocabulary"
        params.source_mapping_file  = "${projectDir}/test/source_mapping.json"
        params.outdir               = 'test_results'
        params.max_memory           = '8.GB'
        params.max_cpus             = 2
        params.max_time             = '1.h'
        params.duckdb_memory        = '4GB'
        params.duckdb_threads       = 2
    }
}

process.shell = ['/bin/bash', '-euo', 'pipefail']

// ─── Helper ───────────────────────────────────────────────────────────────────

def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else return obj
        } catch (all) { return obj }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else return obj
        } catch (all) { return obj }
    } else if (type == 'cpus') {
        try { return Math.min(obj, params.max_cpus as int) }
        catch (all) { return obj }
    }
}
